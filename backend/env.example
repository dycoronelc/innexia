# Database Configuration
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/innovai
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=innovai
DATABASE_USER=root
DATABASE_PASSWORD=password

# JWT Configuration
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"]

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760  # 10MB

# AI Configuration
OPENAI_API_KEY=your-openai-api-key-here
CLAUDE_API_KEY=your-claude-api-key-here
N8N_STRATEGY_ENGINE_WEBHOOK_URL=https://your-n8n-instance/webhook/ai-strategy-engine
N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/innexia-ai-strategy
N8N_TIMEOUT_SECONDS=180
N8N_WORKFLOW_VERSION=v5.2

# Chat gateway: token para callbacks desde n8n (header X-Callback-Token)
CALLBACK_SHARED_TOKEN=my_super_secret_callback_token

# App Configuration
DEBUG=True
HOST=0.0.0.0
PORT=8000
